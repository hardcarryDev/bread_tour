# ============================================================
# 빵투어 (bread tour) - environment variables
# ============================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# Only VITE_-prefixed vars are exposed to the client by Vite.
#
# SECURITY NOTE (NFR-SEC threat model / D10):
# This is a React SPA, so anything in the client bundle is publicly readable.
# The Supabase anon key and Kakao JS key below are PUBLIC client keys — they are
# meant to be exposed in the browser. Data security relies on Supabase RLS
# (NFR-SEC-004) and the Kakao domain allowlist (NFR-SEC-003), NOT on hiding
# these values. They must still come from env (never hardcoded in source).
#
# NEVER put server-only secrets here (e.g. the Supabase service-role key).
# `.env` is gitignored — do not commit real secrets.
# ------------------------------------------------------------

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key — public client key, RLS-protected.
VITE_SUPABASE_ANON_KEY=

# Kakao Maps JavaScript app key — public client key, domain-allowlist protected.
# Used ONLY for client-side map rendering (the Kakao JS SDK). It is NOT used for
# the Mobility directions REST API anymore — directions go through the
# `directions` Supabase Edge Function, which holds the Kakao REST API key as a
# server secret (see supabase/README.md).
VITE_KAKAO_MAP_APP_KEY=

# NOTE: There is intentionally NO client-side Kakao REST key here. The REST key
# lives ONLY in the Edge Function secret KAKAO_REST_API_KEY (set via the Supabase
# CLI, never committed). See supabase/README.md "길찾기 Edge Function" section.
